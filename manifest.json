{
  "manifest_version": 3,
  "name": "PDF Sentence Navigator",
  "version": "1.2.0",
  "description": "Navigate sentences in Chrome PDF viewer with Tab and Shift+Tab.",
  "permissions": [
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "PDF Sentence Navigator"
  }
}